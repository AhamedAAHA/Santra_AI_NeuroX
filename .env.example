# SANTRA AI - Environment Template
# Copy to .env.local and fill values. Do NOT commit secrets.

# ------------------------------------------------------------
# App URLs
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001
SENTRA_APP_URL=http://localhost:3001
NETLIFY_SITE_URL=
SENTRA_TIMEZONE=Asia/Colombo

# ------------------------------------------------------------
# MongoDB Atlas (primary database)
# ------------------------------------------------------------
MONGODB_URI=
MONGODB_DB_NAME=santra

# ------------------------------------------------------------
# Legacy Supabase (optional — no longer required)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# OAuth provisioning script token
SUPABASE_ACCESS_TOKEN=

# Social login provider credentials (MongoDB OAuth — not Supabase)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: sign OAuth state cookies in production
OAUTH_STATE_SECRET=

# ------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL_ANALYSIS=gpt-4o-mini
AIML_MODEL_CHAT=gpt-4o
AIML_MODEL_SEARCH=gpt-4o-search-preview
AIML_MODEL_INTENT=gpt-4o-mini
AIML_MODEL_WORLD=gpt-4o
AIML_MODEL_TRANSCRIBE=#g1_whisper-medium

FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=
FEATHERLESS_MODEL_CHAT=
FEATHERLESS_MODEL_FAST=

OPENAI_API_KEY=

# ------------------------------------------------------------
# Data Providers (legacy + optional)
# ------------------------------------------------------------
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_MANAGEMENT_KEY=
BRIGHT_DATA_SERP_ZONE=
BRIGHT_DATA_WEB_UNLOCKER_ZONE=
BRIGHT_DATA_SCRAPER_ZONE=
BRIGHT_DATA_BROWSER_ZONE=
BRIGHT_DATA_MCP_ENABLED=false
BRIGHT_DATA_MCP_URL=
BRIGHT_DATA_MCP_GROUPS=

# ------------------------------------------------------------
# Voice
# ------------------------------------------------------------
SPEECHMATICS_API_KEY=
SPEECHMATICS_TTS_URL=
SPEECHMATICS_TTS_VOICE=

# ------------------------------------------------------------
# Exa (web search fallback when Bright Data unavailable)
# ------------------------------------------------------------
EXA_API_KEY=

# ------------------------------------------------------------
# Band.io (agent mesh — HITL notifications)
# ------------------------------------------------------------
BAND_AGENT_ID=
BAND_API_KEY=
BAND_AGENT_HANDLE=
BAND_API_BASE_URL=https://app.band.ai

# ------------------------------------------------------------
# Security / Cron
# ------------------------------------------------------------
CRON_SECRET=
SECRETS_SCAN_ENABLED=true

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRA_SHOW_INTEGRATION_STATUS=true
SENTRA_ALLOW_DEMO_FALLBACK=true
